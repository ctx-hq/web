{
  "name": "ctx-web",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.31.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode client && vite build && node --import tsx scripts/post-build.ts",
    "preview": "wrangler pages dev dist",
    "deploy": "pnpm build && wrangler pages deploy dist --commit-dirty=true",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "marked": "^15.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250327.0",
    "@hono/vite-build": "^1.10.1",
    "@hono/vite-dev-server": "^0.18.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^25.5.0",
    "happy-dom": "^20.8.9",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "~3.1.0",
    "wrangler": "^4.14.0"
  }
}
